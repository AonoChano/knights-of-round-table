{
  "name": "kort",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "cd apps/api && python -m uvicorn kort_api.main:app --app-dir src --reload --port 8000",
    "dev:web": "pnpm --dir apps/web dev",
    "build:web": "pnpm --dir apps/web build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
